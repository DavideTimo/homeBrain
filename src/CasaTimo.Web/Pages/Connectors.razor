@page "/connectors"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Connectors — Casa Timò</PageTitle>

<div class="d-flex align-items-center mb-4 gap-2">
    <h3 class="mb-0">Connectors</h3>
    <span class="badge bg-secondary">Admin</span>
</div>

@if (_token is null)
{
    <div class="card border-0 shadow-sm" style="max-width:380px">
        <div class="card-body">
            <h6 class="card-title mb-3">Accesso amministratore</h6>
            <input class="form-control mb-2" @bind="_password" type="password"
                   placeholder="Password" @onkeydown="OnKeyDown" />
            <button class="btn btn-primary w-100" @onclick="Login" disabled="@_loading">
                @(_loading ? "Accesso…" : "Login")
            </button>
            @if (_loginError)
            {
                <div class="alert alert-danger mt-2 mb-0 py-2">Password errata.</div>
            }
        </div>
    </div>
}
else
{
    <div class="d-flex align-items-center gap-2 mb-3">
        <span class="badge bg-success">● Autenticato</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="Logout">Logout</button>
        <button class="btn btn-sm btn-outline-primary ms-auto" @onclick="EnsureViessmannConfig">
            + Setup Viessmann
        </button>
    </div>

    @if (ConnectorList is null || ConnectorList.Count == 0)
    {
        <div class="alert alert-info">
            Nessun connector configurato. Clicca <strong>+ Setup Viessmann</strong> per aggiungere il primo.
        </div>
    }
    else
    {
        <div class="row g-3">
            <!-- Lista connector -->
            <div class="col-12 col-md-3">
                <div class="list-group">
                    @foreach (var c in ConnectorList)
                    {
                        <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center
                                       @(Selected?.ConnectorName == c.ConnectorName ? "active" : "")"
                                @onclick="() => SelectConnector(c.ConnectorName)">
                            <span>@ConnectorIcon(c.ConnectorName) @c.ConnectorName</span>
                            <small class="text-muted @(Selected?.ConnectorName == c.ConnectorName ? "text-white-50" : "")">
                                @c.UpdatedAt.ToLocalTime().ToString("dd/MM HH:mm")
                            </small>
                        </button>
                    }
                </div>
            </div>

            <!-- Dettaglio connector -->
            @if (Selected is not null)
            {
                <div class="col-12 col-md-9">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-transparent d-flex align-items-center gap-2">
                            <span class="fw-semibold">@ConnectorIcon(Selected.ConnectorName) @Selected.ConnectorName</span>
                            <small class="text-muted ms-auto">
                                Aggiornato: @Selected.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                        <div class="card-body">

                            <!-- Diagnostica Viessmann -->
                            @if (Selected.ConnectorName.ToLower() is "viessmann")
                            {
                                <div class="mb-3">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <h6 class="mb-0">📊 Ultima lettura PDC</h6>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshDiagnostics">↻</button>
                                    </div>
                                    @if (_diagLoading)
                                    {
                                        <div class="spinner-border spinner-border-sm text-secondary"></div>
                                    }
                                    else if (_diagReadings is not null && _diagReadings.Count > 0)
                                    {
                                        <div class="row g-2 mb-2">
                                            @foreach (var r in _diagReadings)
                                            {
                                                <div class="col-6 col-lg-3">
                                                    <div class="card border bg-light">
                                                        <div class="card-body py-2 px-3">
                                                            <div class="fw-bold text-primary">
                                                                @r.Value.ToString("F1") <small class="text-muted">@r.Unit</small>
                                                            </div>
                                                            <div class="text-muted small">@DiagLabel(r.Metric)</div>
                                                            <div class="text-muted" style="font-size:.7rem">
                                                                @r.Timestamp.ToLocalTime().ToString("HH:mm:ss")
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <span class="badge @_diagAgeBadgeClass">@_diagAgeText</span>
                                    }
                                    else
                                    {
                                        <div class="text-muted small">
                                            Nessun dato — assicurati che il sidecar Viessmann abbia eseguito almeno un poll.
                                        </div>
                                    }
                                    <hr class="mt-3" />
                                </div>
                            }

                            <!-- Editor JSON -->
                            <label class="form-label fw-semibold">Configurazione JSON</label>
                            <textarea class="form-control font-monospace"
                                      style="height:280px; font-size:.85rem"
                                      @bind="Selected.SettingsJson"></textarea>

                            @if (_saveMessage is not null)
                            {
                                <div class="alert @(_saveError ? "alert-danger" : "alert-success") mt-2 mb-0 py-2">
                                    @_saveMessage
                                </div>
                            }
                            <div class="d-flex gap-2 mt-2">
                                <button class="btn btn-success" @onclick="SaveSelected">💾 Salva</button>
                                @if (Selected.ConnectorName.ToLower() is "viessmann")
                                {
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="FillViessmannTemplate">
                                        📋 Carica template
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private const string ApiBase = "http://localhost:5233";

    private string _password = string.Empty;
    private string? _token;
    private bool _loading;
    private bool _loginError;
    private string? _saveMessage;
    private bool _saveError;

    private List<ConnectorDto>? ConnectorList;
    private ConnectorDto? Selected;

    private List<SensorReading>? _diagReadings;
    private bool _diagLoading;

    // ── Auth ────────────────────────────────────────────────────────────────
    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Login();
    }

    private async Task Login()
    {
        _loading = true;
        _loginError = false;
        try
        {
            var resp = await Http.PostAsJsonAsync($"{ApiBase}/api/auth/token", new { Password = _password });
            if (!resp.IsSuccessStatusCode) { _loginError = true; return; }
            var result = await resp.Content.ReadFromJsonAsync<TokenResponse>();
            _token = result?.Token;
            await LoadConnectors();
        }
        catch { _loginError = true; }
        finally { _loading = false; }
    }

    private void Logout()
    {
        _token = null;
        _password = string.Empty;
        ConnectorList = null;
        Selected = null;
        _saveMessage = null;
        _diagReadings = null;
    }

    // ── Connectors ──────────────────────────────────────────────────────────
    private async Task LoadConnectors()
    {
        try
        {
            ConnectorList = await Http.GetFromJsonAsync<List<ConnectorDto>>($"{ApiBase}/api/connectors");
            Selected = ConnectorList?.FirstOrDefault();
            if (Selected?.ConnectorName.ToLower() == "viessmann")
                await RefreshDiagnostics();
        }
        catch { }
    }

    private async Task SelectConnector(string name)
    {
        try
        {
            Selected = await Http.GetFromJsonAsync<ConnectorDto>($"{ApiBase}/api/connectors/{name}");
            _saveMessage = null;
            _diagReadings = null;
            if (name.ToLower() == "viessmann")
                await RefreshDiagnostics();
        }
        catch { }
    }

    private async Task SaveSelected()
    {
        if (Selected is null || _token is null) return;
        _saveMessage = null;
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Put, $"{ApiBase}/api/connectors/{Selected.ConnectorName}");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", _token);
            req.Content = new StringContent(Selected.SettingsJson ?? string.Empty,
                System.Text.Encoding.UTF8, "application/json");
            var resp = await Http.SendAsync(req);
            _saveError = !resp.IsSuccessStatusCode;
            _saveMessage = resp.IsSuccessStatusCode ? "Salvato con successo." : $"Errore: {resp.StatusCode}";
            if (resp.IsSuccessStatusCode) await LoadConnectors();
        }
        catch (Exception ex) { _saveError = true; _saveMessage = ex.Message; }
    }

    // ── Viessmann setup & diagnostics ───────────────────────────────────────
    private async Task EnsureViessmannConfig()
    {
        if (_token is null) return;
        // Crea il record se non esiste
        var existing = ConnectorList?.FirstOrDefault(c =>
            c.ConnectorName.ToLower() == "viessmann");
        if (existing is null)
        {
            var req = new HttpRequestMessage(HttpMethod.Put, $"{ApiBase}/api/connectors/viessmann");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", _token);
            req.Content = new StringContent(ViessmannTemplate(),
                System.Text.Encoding.UTF8, "application/json");
            await Http.SendAsync(req);
        }
        await LoadConnectors();
        Selected = ConnectorList?.FirstOrDefault(c => c.ConnectorName.ToLower() == "viessmann");
    }

    private void FillViessmannTemplate()
    {
        if (Selected is null) return;
        Selected.SettingsJson = ViessmannTemplate();
        _saveMessage = null;
    }

    private static string ViessmannTemplate() =>
        """
        {
          "installationId": 2949264,
          "gatewaySerial": "7637415018351230",
          "deviceId": "0",
          "deviceModel": "CU401B_S (Vitocal 222-S)",
          "apiBaseUrl": "https://api.viessmann-climatesolutions.com/iot/v2",
          "authUrl": "https://iam.viessmann-climatesolutions.com/idp/v3",
          "redirectUri": "vicare://oauth-callback/everest",
          "pollIntervalSeconds": 300,
          "features": [
            "heating.sensors.temperature.outside",
            "heating.sensors.temperature.return",
            "heating.dhw.sensors.temperature.hotWaterStorage",
            "heating.compressors.0",
            "heating.circuits.0.operating.modes.active"
          ],
          "note": "Credenziali in .env: VIESSMANN_USER, VIESSMANN_PASS, VIESSMANN_CLIENT_ID=ff9de13f..."
        }
        """;

    private async Task RefreshDiagnostics()
    {
        _diagLoading = true;
        try
        {
            var all = await Http.GetFromJsonAsync<List<SensorReading>>(
                $"{ApiBase}/api/sensors/live");
            _diagReadings = all?
                .Where(r => r.DeviceId == "pdc" && r.Unit == "°C")
                .OrderBy(r => r.Metric)
                .ToList();
        }
        catch { _diagReadings = null; }
        finally { _diagLoading = false; }
    }

    // ── Computed helpers ────────────────────────────────────────────────────
    private string _diagAgeBadgeClass => _diagReadings is null || _diagReadings.Count == 0 ? "bg-secondary" :
        (DateTime.UtcNow - _diagReadings.Max(r => r.Timestamp)).TotalMinutes < 15
        ? "bg-success" : "bg-warning text-dark";

    private string _diagAgeText
    {
        get
        {
            if (_diagReadings is null || _diagReadings.Count == 0) return "—";
            var min = (DateTime.UtcNow - _diagReadings.Max(r => r.Timestamp)).TotalMinutes;
            return min < 1 ? "< 1 min fa" : $"{(int)min} min fa";
        }
    }

    // ── Helpers ─────────────────────────────────────────────────────────────
    private static string ConnectorIcon(string name) => name.ToLower() switch
    {
        "viessmann" => "🌡️",
        "huawei"    => "☀️",
        "daikin"    => "❄️",
        "wallbox"   => "🔌",
        _           => "⚙️"
    };

    private static string DiagLabel(string metric) => metric switch
    {
        "outdoor_temp"  => "Temp. esterna",
        "return_temp"   => "Ritorno",
        "supply_temp"   => "Mandata",
        "dhw_temp"      => "ACS",
        _               => metric
    };

    // ── DTOs ────────────────────────────────────────────────────────────────
    private record TokenResponse(string Token);

    private class ConnectorDto
    {
        public int Id { get; set; }
        public string ConnectorName { get; set; } = string.Empty;
        public string? SettingsJson { get; set; }
        public DateTime UpdatedAt { get; set; }
    }

    private class SensorReading
    {
        public string DeviceId { get; set; } = "";
        public string Metric { get; set; } = "";
        public double Value { get; set; }
        public string? Unit { get; set; }
        public DateTime Timestamp { get; set; }
    }
}
