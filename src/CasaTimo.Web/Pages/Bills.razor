@page "/bollette"
@using CasaTimo.Web.Services
@inject BillService BillSvc

<PageTitle>Bollette — Casa Timò</PageTitle>

<div class="container-fluid py-3">
    <h4 class="mb-3">📄 Bollette e Spese</h4>

    <!-- Filters -->
    <div class="card mb-3">
        <div class="card-body d-flex gap-3 flex-wrap align-items-center">
            <select class="form-select form-select-sm" style="width:auto" @bind="_filterYear">
                <option value="0">Tutti gli anni</option>
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <select class="form-select form-select-sm" style="width:auto" @bind="_filterType">
                <option value="">Tutti i tipi</option>
                <option value="Electricity">Luce</option>
                <option value="Water">Acqua</option>
                <option value="Tari">TARI</option>
                <option value="Gas">Gas</option>
                <option value="Maintenance">Manutenzione</option>
            </select>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="unpaidOnly" @bind="_filterUnpaid" />
                <label class="form-check-label" for="unpaidOnly">Solo da pagare</label>
            </div>
            <button class="btn btn-primary btn-sm" @onclick="LoadBills">Cerca</button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
    }
    else if (!_bills.Any())
    {
        <div class="card"><div class="card-body text-center text-muted py-4">Nessuna bolletta trovata</div></div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tipo</th>
                            <th>Emittente</th>
                            <th>Importo</th>
                            <th>Scadenza</th>
                            <th>Periodo</th>
                            <th>Stato</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in _bills)
                        {
                            <tr class="@(bill.IsPaid ? "" : (bill.DueDate < DateTime.Now ? "table-danger" : ""))">
                                <td>
                                    <span class="bill-type-badge bill-@bill.Type.ToString().ToLower()">
                                        @GetBillTypeLabel(bill.Type)
                                    </span>
                                </td>
                                <td>@bill.Issuer</td>
                                <td><strong>€ @bill.Amount.ToString("F2")</strong></td>
                                <td>@bill.DueDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (bill.PeriodFrom.HasValue && bill.PeriodTo.HasValue)
                                    {
                                        <small>@bill.PeriodFrom.Value.ToString("MM/yy") – @bill.PeriodTo.Value.ToString("MM/yy")</small>
                                    }
                                </td>
                                <td>
                                    @if (bill.IsPaid)
                                    {
                                        <span class="badge bg-success">Pagata</span>
                                    }
                                    else if (bill.DueDate < DateTime.Now)
                                    {
                                        <span class="badge bg-danger">Scaduta!</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Da pagare</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        @if (bill.PdfPath != null)
                                        {
                                            <a href="/api/bills/@bill.Id/pdf" target="_blank" class="btn btn-outline-secondary btn-sm">📄 PDF</a>
                                        }
                                        @if (!bill.IsPaid)
                                        {
                                            <button class="btn btn-outline-success btn-sm" @onclick="() => MarkPaid(bill.Id)">✓ Pagata</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-3 text-muted small">
            Totale: <strong>€ @_bills.Sum(b => b.Amount).ToString("F2")</strong>
            | @_bills.Count(b => !b.IsPaid) bollette da pagare
        </div>
    }
</div>

@code {
    private List<BillDto> _bills = [];
    private bool _loading = true;
    private int _filterYear = DateTime.Now.Year;
    private string _filterType = "";
    private bool _filterUnpaid = false;

    protected override async Task OnInitializedAsync() => await LoadBills();

    private async Task LoadBills()
    {
        _loading = true;
        _bills = await BillSvc.GetBillsAsync(_filterYear > 0 ? _filterYear : null, _filterType, _filterUnpaid);
        _loading = false;
    }

    private async Task MarkPaid(int id)
    {
        await BillSvc.MarkPaidAsync(id);
        await LoadBills();
    }

    private static string GetBillTypeLabel(BillType type) => type switch
    {
        BillType.Electricity => "⚡ Luce",
        BillType.Water => "💧 Acqua",
        BillType.Tari => "♻️ TARI",
        BillType.Gas => "🔥 Gas",
        BillType.Maintenance => "🔧 Manutenzione",
        _ => "📋 Altro"
    };

}
