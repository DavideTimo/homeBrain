@inject IJSRuntime JS
@implements IAsyncDisposable

@if (_updateAvailable)
{
    <MudAlert Severity="Severity.Info"
              Style="position: sticky; top: 0; z-index: 1050; border-radius: 0;"
              Class="mb-0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <span>&#x1F504; &Egrave; disponibile una nuova versione di Casa Tim&#242;.</span>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="ApplyUpdate">Aggiorna ora</MudButton>
        </MudStack>
    </MudAlert>
}

@code {
    private bool _updateAvailable;
    private Timer? _timer;

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        _timer = new Timer(async _ =>
        {
            var available = await JS.InvokeAsync<bool>("checkSwUpdate");
            if (available && !_updateAvailable)
            {
                _updateAvailable = true;
                await InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(30));
    }

    private async Task ApplyUpdate()
        => await JS.InvokeVoidAsync("applySwUpdate");

    public async ValueTask DisposeAsync()
    {
        if (_timer != null) await _timer.DisposeAsync();
    }
}
