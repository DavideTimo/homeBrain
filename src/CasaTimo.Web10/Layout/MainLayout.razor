@inherits LayoutComponentBase
@using CasaTimo.Web10.Services
@inject AuthService Auth
@inject NavigationManager Nav

<UpdateBanner />

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-end align-items-center">
            <AuthorizeView>
                <Authorized>
                    <span class="text-muted me-3 small">@context.User.Identity?.Name</span>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="Logout">Esci</button>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
