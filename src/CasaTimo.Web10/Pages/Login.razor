@page "/login"
@using CasaTimo.Web10.Services
@inject AuthService Auth
@inject NavigationManager Nav

<MudGrid Justify="Justify.Center" Style="min-height: 100vh; align-items: center;">
    <MudItem xs="12" sm="8" md="5" lg="4">
        <MudCard Elevation="4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Align="Align.Center">Casa Timò</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">Accedi per continuare</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (_error != null)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                }
                <EditForm Model="_model" OnValidSubmit="HandleLogin">
                    <DataAnnotationsValidator />
                    <MudTextField @bind-Value="_model.Username"
                                  Label="Utente"
                                  Variant="Variant.Outlined"
                                  Class="mb-3"
                                  autocomplete="username" />
                    <MudTextField @bind-Value="_model.Password"
                                  Label="Password"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Password"
                                  Class="mb-4"
                                  autocomplete="current-password" />
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Disabled="@_loading">
                        @if (_loading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Accedi
                    </MudButton>
                </EditForm>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private readonly LoginModel _model = new();
    private bool _loading;
    private string? _error;

    private async Task HandleLogin()
    {
        _loading = true;
        _error = null;
        var ok = await Auth.LoginAsync(_model.Username, _model.Password);
        _loading = false;
        if (ok)
            Nav.NavigateTo("/");
        else
            _error = "Credenziali non valide.";
    }

    private sealed class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
