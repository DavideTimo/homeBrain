@page "/manutenzione"
@attribute [Authorize]
@inject ApiClient Api

<PageTitle>Manutenzioni &mdash; Casa Tim&#242;</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Manutenzioni</MudText>

@if (_loading)
{
    <MudAlert Severity="Severity.Info">Caricamento...</MudAlert>
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudGrid>
        <MudItem xs="12" lg="8">
            <MudText Typo="Typo.h6" Class="mb-3">Storico interventi</MudText>
            @if (_records == null || _records.Count == 0)
            {
                <MudAlert Severity="Severity.Normal">Nessun intervento registrato.</MudAlert>
            }
            else
            {
                @foreach (var rec in _records.OrderByDescending(r => r.Date))
                {
                    <MudCard Class="mb-3">
                        <MudCardContent>
                            <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                                <div>
                                    <MudText Typo="Typo.subtitle1"><strong>@rec.DeviceId</strong></MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@(rec.Description ?? "Nessuna descrizione")</MudText>
                                    <div class="mt-1">
                                        @if (rec.Cost.HasValue)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Costo: &euro;@rec.Cost.Value.ToString("N2")</MudChip>
                                        }
                                        @if (rec.NextDueDate.HasValue)
                                        {
                                            var days = (int)(rec.NextDueDate.Value.Date - DateTime.Today).TotalDays;
                                            var color = days < 0 ? Color.Error : days <= 30 ? Color.Warning : Color.Info;
                                            <MudChip T="string" Size="Size.Small" Color="@color">Prossimo: @rec.NextDueDate.Value.ToString("dd/MM/yyyy")</MudChip>
                                        }
                                    </div>
                                </div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@rec.Date.ToString("dd/MM/yyyy")</MudText>
                            </div>
                        </MudCardContent>
                    </MudCard>
                }
            }
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Aggiungi intervento</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_formError != null)
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-3">@_formError</MudAlert>
                    }
                    @if (_formSuccess)
                    {
                        <MudAlert Severity="Severity.Success" Class="mb-3">Intervento aggiunto.</MudAlert>
                    }

                    <MudSelect T="string" Label="Dispositivo *" @bind-Value="_form.DeviceId" Class="mb-3">
                        @if (_devices != null)
                        {
                            @foreach (var d in _devices)
                            {
                                <MudSelectItem Value="@d.Id">@d.Name (@d.Id)</MudSelectItem>
                            }
                        }
                    </MudSelect>

                    <MudTextField T="string" Label="Descrizione" Lines="3" @bind-Value="_form.Description" Class="mb-3" />

                    <MudDatePicker Label="Data intervento *" @bind-Date="_formDate" Class="mb-3" />

                    <MudTextField T="decimal?" Label="Costo (euro)" @bind-Value="_form.Cost" Class="mb-3" />

                    <MudDatePicker Label="Prossima scadenza" @bind-Date="_formNextDue" Class="mb-3" />

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               OnClick="SubmitForm" Disabled="@_submitting">
                        @(_submitting ? "Salvataggio..." : "Aggiungi")
                    </MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<MaintenanceRecordDto>? _records;
    private List<DeviceDto>? _devices;

    private bool _submitting;
    private string? _formError;
    private bool _formSuccess;

    private FormModel _form = new();
    private DateTime? _formDate = DateTime.Today;
    private DateTime? _formNextDue;

    private class FormModel
    {
        public string DeviceId { get; set; } = "";
        public string? Description { get; set; }
        public decimal? Cost { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var recordsTask = Api.GetMaintenanceAsync();
            var devicesTask = Api.GetDevicesAsync();
            await Task.WhenAll(recordsTask, devicesTask);
            _records = await recordsTask ?? new List<MaintenanceRecordDto>();
            _devices = await devicesTask ?? new List<DeviceDto>();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SubmitForm()
    {
        _formError = null;
        _formSuccess = false;

        if (string.IsNullOrWhiteSpace(_form.DeviceId))
        {
            _formError = "Seleziona un dispositivo.";
            return;
        }

        _submitting = true;
        try
        {
            var dto = new MaintenanceRecordDto(
                Id: 0,
                DeviceId: _form.DeviceId,
                Description: _form.Description,
                Date: _formDate ?? DateTime.Today,
                Cost: _form.Cost,
                NextDueDate: _formNextDue
            );
            await Api.AddMaintenanceAsync(dto);
            _formSuccess = true;
            _form = new FormModel();
            _formDate = DateTime.Today;
            _formNextDue = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formError = $"Errore: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
