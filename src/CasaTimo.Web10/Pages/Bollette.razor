@page "/bollette"
@attribute [Authorize]
@inject ApiClient Api

<PageTitle>Bollette &mdash; Casa Timò</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Bollette</MudText>

@if (_loading)
{
    <MudAlert Severity="Severity.Info">Caricamento bollette...</MudAlert>
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error"><strong>Errore:</strong> @_error</MudAlert>
}
else
{
    <MudButtonGroup Class="mb-4" Variant="Variant.Outlined">
        <MudButton Color="@(_filter == "all" ? Color.Primary : Color.Default)"
                   Variant="@(_filter == "all" ? Variant.Filled : Variant.Outlined)"
                   OnClick='() => SetFilter("all")'>Tutte</MudButton>
        <MudButton Color="@(_filter == "unpaid" ? Color.Warning : Color.Default)"
                   Variant="@(_filter == "unpaid" ? Variant.Filled : Variant.Outlined)"
                   OnClick='() => SetFilter("unpaid")'>Da pagare</MudButton>
        <MudButton Color="@(_filter == "paid" ? Color.Success : Color.Default)"
                   Variant="@(_filter == "paid" ? Variant.Filled : Variant.Outlined)"
                   OnClick='() => SetFilter("paid")'>Pagate</MudButton>
    </MudButtonGroup>

    @if (_filtered == null || _filtered.Count == 0)
    {
        <MudAlert Severity="Severity.Normal">Nessuna bolletta trovata.</MudAlert>
    }
    else
    {
        <MudTable Items="@_filtered" Striped="true" Hover="true" Dense="false">
            <HeaderContent>
                <MudTh>Tipo</MudTh>
                <MudTh>Emittente</MudTh>
                <MudTh>Importo</MudTh>
                <MudTh>Scadenza</MudTh>
                <MudTh>Periodo</MudTh>
                <MudTh>Pagata</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Secondary">@MapBillType(context.Type)</MudChip></MudTd>
                <MudTd>@context.Issuer</MudTd>
                <MudTd><strong>&euro;@context.Amount.ToString("N2")</strong></MudTd>
                <MudTd>@context.DueDate.ToString("dd/MM/yyyy")</MudTd>
                <MudTd>
                    @if (context.PeriodFrom.HasValue && context.PeriodTo.HasValue)
                    {
                        <text>@context.PeriodFrom.Value.ToString("MMM yyyy") &ndash; @context.PeriodTo.Value.ToString("MMM yyyy")</text>
                    }
                    else
                    {
                        <text>&mdash;</text>
                    }
                </MudTd>
                <MudTd>
                    @if (context.IsPaid)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" />
                    }
                </MudTd>
                <MudTd>
                    @if (!context.IsPaid)
                    {
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Outlined"
                                   Color="Color.Success"
                                   OnClick="() => MarkPaid(context.Id)"
                                   Disabled="@_paying.Contains(context.Id)">
                            @(_paying.Contains(context.Id) ? "..." : "Segna pagata")
                        </MudButton>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<BillDto>? _bills;
    private List<BillDto>? _filtered;
    private string _filter = "all";
    private HashSet<long> _paying = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _bills = await Api.GetBillsAsync() ?? new List<BillDto>();
            ApplyFilter();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetFilter(string f)
    {
        _filter = f;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        _filtered = _filter switch
        {
            "unpaid" => _bills?.Where(b => !b.IsPaid).ToList(),
            "paid"   => _bills?.Where(b => b.IsPaid).ToList(),
            _        => _bills?.ToList()
        };
    }

    private async Task MarkPaid(long id)
    {
        _paying.Add(id);
        try
        {
            await Api.MarkBillPaidAsync(id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Errore durante il salvataggio: {ex.Message}";
        }
        finally
        {
            _paying.Remove(id);
        }
    }

    private static string MapBillType(int t) => t switch
    {
        0 => "Luce",
        1 => "Acqua",
        2 => "TARI",
        3 => "Manutenzione",
        4 => "Altro",
        _ => $"Tipo {t}"
    };
}
