@page "/"
@attribute [Authorize]
@inject ApiClient Api
@implements IDisposable

<PageTitle>Dashboard &mdash; Casa Timò</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard &mdash; Casa Timò</MudText>

<MudText Typo="Typo.h5" Class="mb-2">Sensori Live</MudText>
<MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">Aggiornamento automatico ogni 30s</MudText>

@if (_sensorsLoading)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">Caricamento sensori...</MudAlert>
}
else if (_sensorsError != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4"><strong>Errore API:</strong> @_sensorsError</MudAlert>
}
else if (_sensorGroups == null || _sensorGroups.Count == 0)
{
    <MudAlert Severity="Severity.Normal" Class="mb-4">Nessun dato sensore disponibile.</MudAlert>
}
else
{
    <MudGrid Class="mb-5">
        @foreach (var group in _sensorGroups)
        {
            <MudItem xs="12" md="6" xl="4">
                <MudCard Height="100%">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@DeviceLabel(group.Key)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudSimpleTable Dense="true" Striped="true">
                            <thead>
                                <tr>
                                    <th>Metrica</th>
                                    <th>Valore</th>
                                    <th>Unità</th>
                                    <th>Timestamp</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in group.Value)
                                {
                                    <tr>
                                        <td>@MetricLabel(r.Metric)</td>
                                        <td><strong>@r.Value.ToString("G4")</strong></td>
                                        <td>@(r.Unit ?? "—")</td>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">@r.Timestamp.ToLocalTime().ToString("HH:mm:ss")</MudText></td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

<MudText Typo="Typo.h5" Class="mb-3">Reminder Attivi</MudText>

@if (_remindersLoading)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">Caricamento reminder...</MudAlert>
}
else if (_remindersError != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4"><strong>Errore API:</strong> @_remindersError</MudAlert>
}
else if (_activeReminders == null || _activeReminders.Count == 0)
{
    <MudAlert Severity="Severity.Success" Class="mb-4">&#10003; Nessuna scadenza imminente.</MudAlert>
}
else
{
    <MudGrid Class="mb-5">
        @foreach (var r in _activeReminders)
        {
            var daysLeft = (int)(r.DueDate.Date - DateTime.Today).TotalDays;
            var severity = daysLeft <= 3 ? Severity.Error : daysLeft <= 7 ? Severity.Warning : Severity.Info;
            <MudItem xs="12" md="6">
                <MudAlert Severity="@severity" Class="mb-0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <strong>@(r.Message ?? $"Reminder bolletta #{r.BillId}")</strong>
                        <MudChip T="string" Color="Color.Dark" Size="Size.Small">
                            @if (daysLeft == 0) { <text>Oggi</text> }
                            else if (daysLeft < 0) { <text>Scaduto</text> }
                            else { <text>tra @daysLeft giorni</text> }
                        </MudChip>
                    </MudStack>
                    <MudText Typo="Typo.caption">Scadenza: @r.DueDate.ToString("dd/MM/yyyy")</MudText>
                </MudAlert>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private bool _sensorsLoading = true;
    private bool _remindersLoading = true;
    private string? _sensorsError;
    private string? _remindersError;
    private Dictionary<string, List<SensorReadingDto>>? _sensorGroups;
    private List<ReminderDto>? _activeReminders;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadAllAsync();
        _timer = new Timer(async _ =>
        {
            await LoadAllAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadAllAsync()
    {
        await Task.WhenAll(LoadSensorsAsync(), LoadRemindersAsync());
    }

    private async Task LoadSensorsAsync()
    {
        _sensorsLoading = true;
        _sensorsError = null;
        try
        {
            var readings = await Api.GetSensorLiveAsync();
            _sensorGroups = readings?
                .GroupBy(r => r.DeviceId)
                .ToDictionary(g => g.Key, g => g.ToList())
                ?? new Dictionary<string, List<SensorReadingDto>>();
        }
        catch (Exception ex)
        {
            _sensorsError = ex.Message;
            _sensorGroups = null;
        }
        finally
        {
            _sensorsLoading = false;
        }
    }

    private async Task LoadRemindersAsync()
    {
        _remindersLoading = true;
        _remindersError = null;
        try
        {
            var all = await Api.GetRemindersAsync();
            _activeReminders = all?.Where(r => !r.IsSent).OrderBy(r => r.DueDate).ToList()
                ?? new List<ReminderDto>();
        }
        catch (Exception ex)
        {
            _remindersError = ex.Message;
            _activeReminders = null;
        }
        finally
        {
            _remindersLoading = false;
        }
    }

    public void Dispose() => _timer?.Dispose();

    private static string DeviceLabel(string deviceId) => deviceId.ToLower() switch
    {
        "pdc"     => "🔥 Pompa di Calore",
        "fv"      => "☀️ Fotovoltaico & Batteria",
        "vmc"     => "💨 VMC",
        "daikin"  => "❄️ Clima Daikin",
        "wallbox" => "⚡ Wallbox",
        _ => deviceId.ToUpperInvariant()
    };

    private static string MetricLabel(string metric) => metric.ToLower() switch
    {
        "temperature/outside"     => "Temperatura esterna",
        "temperature/supply"      => "Temperatura mandata",
        "temperature/return"      => "Temperatura ritorno",
        "dhw/temperature"         => "Acqua calda sanitaria",
        "dhw/charging"            => "Ricarica ACS",
        "power/consumption"       => "Consumo elettrico",
        "power/output"            => "Potenza termica",
        "compressor/hours"        => "Ore compressore",
        "compressor/starts"       => "Avvii compressore",
        "mode"                    => "Modalità",
        "power/production"        => "Produzione FV",
        "energy/today"            => "Energia oggi",
        "battery/soc"             => "Carica batteria",
        "battery/power"           => "Flusso batteria",
        "battery/status"          => "Stato batteria",
        "battery/temperature"     => "Temperatura batteria",
        "grid/power"              => "Scambio rete",
        "inverter/temperature"    => "Temperatura inverter",
        "inverter/state"          => "Stato inverter",
        "humidity/extract"        => "Umidità ripresa",
        "humidity/supply"         => "Umidità mandata",
        // Daikin
        "zone/0/power"            => "Zona 1 — Accensione",
        "zone/0/mode"             => "Zona 1 — Modalità",
        "zone/0/temperature/room"     => "Zona 1 — Temp. stanza",
        "zone/0/temperature/setpoint" => "Zona 1 — Setpoint",
        "zone/0/fan/speed"        => "Zona 1 — Velocità ventola",
        "zone/1/power"            => "Zona 2 — Accensione",
        "zone/1/mode"             => "Zona 2 — Modalità",
        "zone/1/temperature/room"     => "Zona 2 — Temp. stanza",
        "zone/1/temperature/setpoint" => "Zona 2 — Setpoint",
        "zone/2/power"            => "Zona 3 — Accensione",
        "zone/2/temperature/room"     => "Zona 3 — Temp. stanza",
        // Wallbox
        "status"                  => "Stato",
        "power"                   => "Potenza ricarica",
        "session/energy"          => "Energia sessione",
        "session/start"           => "Inizio sessione",
        "session/stop"            => "Fine sessione",
        _ => metric
    };
}
