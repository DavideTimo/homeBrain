@page "/impostazioni"
@attribute [Authorize]
@inject ApiClient Api
@inject NotificationService PushService
@inject IJSRuntime JS

<PageTitle>Impostazioni — Casa Timò</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Impostazioni</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Le modifiche ai connettori richiedono il riavvio del servizio Workers per essere applicate.</MudText>

<!-- Push notifications card -->
<MudCard Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Notifications" />
                <MudText Typo="Typo.h6">Notifiche Push</MudText>
            </MudStack>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (!_pushSupported)
        {
            <MudText Color="Color.Secondary">Le notifiche push non sono supportate da questo browser.</MudText>
        }
        else if (_pushSubscribed)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudText Color="Color.Success"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" />Notifiche attive su questo dispositivo</MudText>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="DisableNotifications">Disabilita</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="SendTestNotification">Invia test</MudButton>
            </MudStack>
        }
        else
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudText Color="Color.Secondary">Ricevi notifiche push per le scadenze bollette.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="EnableNotifications" Disabled="@_pushLoading">
                    @(_pushLoading ? "..." : "Abilita notifiche")
                </MudButton>
            </MudStack>
        }
        @if (_pushMessage != null)
        {
            <MudAlert Severity="@(_pushError ? Severity.Error : Severity.Success)" Class="mt-2">@_pushMessage</MudAlert>
        }
    </MudCardContent>
</MudCard>

@if (_loading)
{
    <MudAlert Severity="Severity.Info">Caricamento...</MudAlert>
}
else
{
    <MudExpansionPanels>

        <!-- Viessmann -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle1"><strong>Viessmann (PDC + VMC)</strong></MudText>
                    @if (_viessmannUpdatedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Aggiornato: @_viessmannUpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</MudText>
                    }
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_viessmann.ApiBaseUrl" Label="API Base URL" Variant="Variant.Outlined" Placeholder="https://api.viessmann.com" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_viessmann.TokenEndpoint" Label="Token Endpoint" Variant="Variant.Outlined" Placeholder="https://iam.viessmann.com/idp/v3/token" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_viessmann.ClientId" Label="Client ID" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_viessmann.ClientSecret" Label="Client Secret" Variant="Variant.Outlined" InputType="InputType.Password" autocomplete="off" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_viessmann.InstallationId" Label="Installation ID (opzionale)" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_viessmann.GatewaySerial" Label="Gateway Serial (opzionale)" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="int" @bind-Value="_viessmannPollMinutes" Label="Intervallo di polling" Variant="Variant.Outlined">
                            <MudSelectItem T="int" Value="60">1 min</MudSelectItem>
                            <MudSelectItem T="int" Value="300">5 min</MudSelectItem>
                            <MudSelectItem T="int" Value="600">10 min</MudSelectItem>
                            <MudSelectItem T="int" Value="900">15 min</MudSelectItem>
                            <MudSelectItem T="int" Value="1800">30 min</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveViessmann" Disabled="@_viessmannSaving">
                                @if (_viessmannSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Salva
                            </MudButton>
                            @if (_viessmannMsg != null)
                            {
                                <MudText Color="@(_viessmannError ? Color.Error : Color.Success)" Typo="Typo.body2">@_viessmannMsg</MudText>
                            }
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Huawei FusionSolar -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle1"><strong>Huawei FusionSolar</strong></MudText>
                    @if (_huaweiUpdatedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Aggiornato: @_huaweiUpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</MudText>
                    }
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_huawei.BaseUrl" Label="Base URL" Variant="Variant.Outlined" Placeholder="https://uni005eu5.fusionsolar.huawei.com" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_huawei.UserName" Label="Username" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_huawei.SystemCode" Label="System Code" Variant="Variant.Outlined" InputType="InputType.Password" autocomplete="off" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_huawei.StationCode" Label="Station Code (opzionale)" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="int" @bind-Value="_huaweiPollMinutes" Label="Intervallo di polling" Variant="Variant.Outlined">
                            <MudSelectItem T="int" Value="60">1 min</MudSelectItem>
                            <MudSelectItem T="int" Value="300">5 min</MudSelectItem>
                            <MudSelectItem T="int" Value="600">10 min</MudSelectItem>
                            <MudSelectItem T="int" Value="900">15 min</MudSelectItem>
                            <MudSelectItem T="int" Value="1800">30 min</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveHuawei" Disabled="@_huaweiSaving">
                                @if (_huaweiSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Salva
                            </MudButton>
                            @if (_huaweiMsg != null)
                            {
                                <MudText Color="@(_huaweiError ? Color.Error : Color.Success)" Typo="Typo.body2">@_huaweiMsg</MudText>
                            }
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Daikin Cloud -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle1"><strong>Daikin Cloud</strong></MudText>
                    @if (_daikinUpdatedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Aggiornato: @_daikinUpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</MudText>
                    }
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_daikin.TokenEndpoint" Label="Token Endpoint" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_daikin.ApiBaseUrl" Label="API Base URL" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_daikin.ClientId" Label="Client ID" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_daikin.Username" Label="Username" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_daikin.Password" Label="Password" Variant="Variant.Outlined" InputType="InputType.Password" autocomplete="off" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="int" @bind-Value="_daikinPollMinutes" Label="Intervallo di polling" Variant="Variant.Outlined">
                            <MudSelectItem T="int" Value="60">1 min</MudSelectItem>
                            <MudSelectItem T="int" Value="300">5 min</MudSelectItem>
                            <MudSelectItem T="int" Value="600">10 min</MudSelectItem>
                            <MudSelectItem T="int" Value="900">15 min</MudSelectItem>
                            <MudSelectItem T="int" Value="1800">30 min</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDaikin" Disabled="@_daikinSaving">
                                @if (_daikinSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Salva
                            </MudButton>
                            @if (_daikinMsg != null)
                            {
                                <MudText Color="@(_daikinError ? Color.Error : Color.Success)" Typo="Typo.body2">@_daikinMsg</MudText>
                            }
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Wallbox OCPP -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle1"><strong>Wallbox OCPP</strong></MudText>
                    @if (_wallboxUpdatedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Aggiornato: @_wallboxUpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</MudText>
                    }
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudNumericField T="int" @bind-Value="_wallbox.Port" Label="Porta" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_wallbox.AuthKey" Label="Auth Key (opzionale)" Variant="Variant.Outlined" InputType="InputType.Password" autocomplete="off" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudNumericField T="int" @bind-Value="_wallbox.HeartbeatTimeoutSeconds" Label="Heartbeat Timeout (secondi)" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveWallbox" Disabled="@_wallboxSaving">
                                @if (_wallboxSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Salva
                            </MudButton>
                            @if (_wallboxMsg != null)
                            {
                                <MudText Color="@(_wallboxError ? Color.Error : Color.Success)" Typo="Typo.body2">@_wallboxMsg</MudText>
                            }
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </ChildContent>
        </MudExpansionPanel>

        <!-- MQTT Broker -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle1"><strong>MQTT Broker</strong></MudText>
                    @if (_mqttUpdatedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Aggiornato: @_mqttUpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</MudText>
                    }
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_mqtt.Host" Label="Host" Variant="Variant.Outlined" Placeholder="localhost" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int" @bind-Value="_mqtt.Port" Label="Porta" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_mqtt.ClientId" Label="Client ID" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_mqtt.Username" Label="Username (opzionale)" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_mqtt.Password" Label="Password (opzionale)" Variant="Variant.Outlined" InputType="InputType.Password" autocomplete="off" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudCheckBox @bind-Value="_mqtt.UseTls" Label="Usa TLS" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveMqtt" Disabled="@_mqttSaving">
                                @if (_mqttSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Salva
                            </MudButton>
                            @if (_mqttMsg != null)
                            {
                                <MudText Color="@(_mqttError ? Color.Error : Color.Success)" Typo="Typo.body2">@_mqttMsg</MudText>
                            }
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </ChildContent>
        </MudExpansionPanel>

    </MudExpansionPanels>
}

@code {
    // ── page state ────────────────────────────────────────────────────────────
    private bool _loading = true;

    // ── push notification state ───────────────────────────────────────────────
    private bool _pushSupported;
    private bool _pushSubscribed;
    private bool _pushLoading;
    private string? _pushMessage;
    private bool _pushError;

    // ── Viessmann ─────────────────────────────────────────────────────────────
    private ViessmannSettings _viessmann = new();
    private int _viessmannPollMinutes = 300;
    private DateTime? _viessmannUpdatedAt;
    private bool _viessmannSaving;
    private string? _viessmannMsg;
    private bool _viessmannError;

    // ── Huawei FusionSolar ────────────────────────────────────────────────────
    private HuaweiSettings _huawei = new();
    private int _huaweiPollMinutes = 300;
    private DateTime? _huaweiUpdatedAt;
    private bool _huaweiSaving;
    private string? _huaweiMsg;
    private bool _huaweiError;

    // ── Daikin Cloud ──────────────────────────────────────────────────────────
    private DaikinSettings _daikin = new();
    private int _daikinPollMinutes = 300;
    private DateTime? _daikinUpdatedAt;
    private bool _daikinSaving;
    private string? _daikinMsg;
    private bool _daikinError;

    // ── Wallbox OCPP ──────────────────────────────────────────────────────────
    private WallboxSettings _wallbox = new();
    private DateTime? _wallboxUpdatedAt;
    private bool _wallboxSaving;
    private string? _wallboxMsg;
    private bool _wallboxError;

    // ── MQTT Broker ───────────────────────────────────────────────────────────
    private MqttSettings _mqtt = new();
    private DateTime? _mqttUpdatedAt;
    private bool _mqttSaving;
    private string? _mqttMsg;
    private bool _mqttError;

    // ── lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // Push support check
        _pushSupported = await PushService.IsSupportedAsync();
        if (_pushSupported)
            _pushSubscribed = await PushService.IsSubscribedAsync();

        // Load connector configs
        await LoadConnectorsAsync();

        _loading = false;
    }

    private async Task LoadConnectorsAsync()
    {
        await LoadConnector("viessmann", dto =>
        {
            _viessmannUpdatedAt = dto.UpdatedAt;
            var s = Deserialize<ViessmannSettings>(dto.SettingsJson);
            if (s != null)
            {
                _viessmann = s;
                _viessmannPollMinutes = s.PollIntervalSeconds;
            }
        });

        await LoadConnector("huawei", dto =>
        {
            _huaweiUpdatedAt = dto.UpdatedAt;
            var s = Deserialize<HuaweiSettings>(dto.SettingsJson);
            if (s != null)
            {
                _huawei = s;
                _huaweiPollMinutes = s.PollIntervalSeconds;
            }
        });

        await LoadConnector("daikin", dto =>
        {
            _daikinUpdatedAt = dto.UpdatedAt;
            var s = Deserialize<DaikinSettings>(dto.SettingsJson);
            if (s != null)
            {
                _daikin = s;
                _daikinPollMinutes = s.PollIntervalSeconds;
            }
        });

        await LoadConnector("wallbox", dto =>
        {
            _wallboxUpdatedAt = dto.UpdatedAt;
            var s = Deserialize<WallboxSettings>(dto.SettingsJson);
            if (s != null) _wallbox = s;
        });

        await LoadConnector("mqtt", dto =>
        {
            _mqttUpdatedAt = dto.UpdatedAt;
            var s = Deserialize<MqttSettings>(dto.SettingsJson);
            if (s != null) _mqtt = s;
        });
    }

    private async Task LoadConnector(string name, Action<ConnectorConfigDto> apply)
    {
        try
        {
            var dto = await Api.GetConnectorConfigAsync(name);
            if (dto != null) apply(dto);
        }
        catch { /* connector not yet configured — use defaults */ }
    }

    private static readonly System.Text.Json.JsonSerializerOptions _jsonOpts = new()
    {
        PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };

    private static T? Deserialize<T>(string json)
    {
        try { return System.Text.Json.JsonSerializer.Deserialize<T>(json, _jsonOpts); }
        catch { return default; }
    }

    private static string Serialize<T>(T obj)
        => System.Text.Json.JsonSerializer.Serialize(obj, _jsonOpts);

    // ── push notification methods ─────────────────────────────────────────────
    private async Task EnableNotifications()
    {
        _pushLoading = true;
        _pushMessage = null;
        try
        {
            var ok = await PushService.SubscribeAsync();
            if (ok)
            {
                _pushSubscribed = true;
                _pushError = false;
                _pushMessage = "Notifiche abilitate.";
            }
            else
            {
                _pushError = true;
                _pushMessage = "Impossibile abilitare le notifiche. Controlla i permessi del browser.";
            }
        }
        catch (Exception ex)
        {
            _pushError = true;
            _pushMessage = $"Errore: {ex.Message}";
        }
        finally
        {
            _pushLoading = false;
        }
    }

    private async Task DisableNotifications()
    {
        _pushMessage = null;
        try
        {
            await PushService.UnsubscribeAsync();
            _pushSubscribed = false;
            _pushError = false;
            _pushMessage = "Notifiche disabilitate.";
        }
        catch (Exception ex)
        {
            _pushError = true;
            _pushMessage = $"Errore: {ex.Message}";
        }
    }

    private async Task SendTestNotification()
    {
        _pushMessage = null;
        try
        {
            await Api.SendTestPushAsync();
            _pushError = false;
            _pushMessage = "Notifica di test inviata.";
        }
        catch (Exception ex)
        {
            _pushError = true;
            _pushMessage = $"Errore: {ex.Message}";
        }
    }

    // ── save helpers ──────────────────────────────────────────────────────────
    private async Task SaveViessmann()
    {
        _viessmannSaving = true;
        _viessmannMsg = null;
        try
        {
            _viessmann.PollIntervalSeconds = _viessmannPollMinutes;
            await Api.SaveConnectorConfigAsync("viessmann", Serialize(_viessmann));
            _viessmannUpdatedAt = DateTime.Now;
            _viessmannError = false;
            _viessmannMsg = "✓ Salvato";
            _ = ClearMsgAfterDelayAsync(() => _viessmannMsg = null);
        }
        catch (Exception ex)
        {
            _viessmannError = true;
            _viessmannMsg = $"Errore: {ex.Message}";
        }
        finally { _viessmannSaving = false; }
    }

    private async Task SaveHuawei()
    {
        _huaweiSaving = true;
        _huaweiMsg = null;
        try
        {
            _huawei.PollIntervalSeconds = _huaweiPollMinutes;
            await Api.SaveConnectorConfigAsync("huawei", Serialize(_huawei));
            _huaweiUpdatedAt = DateTime.Now;
            _huaweiError = false;
            _huaweiMsg = "✓ Salvato";
            _ = ClearMsgAfterDelayAsync(() => _huaweiMsg = null);
        }
        catch (Exception ex)
        {
            _huaweiError = true;
            _huaweiMsg = $"Errore: {ex.Message}";
        }
        finally { _huaweiSaving = false; }
    }

    private async Task SaveDaikin()
    {
        _daikinSaving = true;
        _daikinMsg = null;
        try
        {
            _daikin.PollIntervalSeconds = _daikinPollMinutes;
            await Api.SaveConnectorConfigAsync("daikin", Serialize(_daikin));
            _daikinUpdatedAt = DateTime.Now;
            _daikinError = false;
            _daikinMsg = "✓ Salvato";
            _ = ClearMsgAfterDelayAsync(() => _daikinMsg = null);
        }
        catch (Exception ex)
        {
            _daikinError = true;
            _daikinMsg = $"Errore: {ex.Message}";
        }
        finally { _daikinSaving = false; }
    }

    private async Task SaveWallbox()
    {
        _wallboxSaving = true;
        _wallboxMsg = null;
        try
        {
            await Api.SaveConnectorConfigAsync("wallbox", Serialize(_wallbox));
            _wallboxUpdatedAt = DateTime.Now;
            _wallboxError = false;
            _wallboxMsg = "✓ Salvato";
            _ = ClearMsgAfterDelayAsync(() => _wallboxMsg = null);
        }
        catch (Exception ex)
        {
            _wallboxError = true;
            _wallboxMsg = $"Errore: {ex.Message}";
        }
        finally { _wallboxSaving = false; }
    }

    private async Task SaveMqtt()
    {
        _mqttSaving = true;
        _mqttMsg = null;
        try
        {
            await Api.SaveConnectorConfigAsync("mqtt", Serialize(_mqtt));
            _mqttUpdatedAt = DateTime.Now;
            _mqttError = false;
            _mqttMsg = "✓ Salvato";
            _ = ClearMsgAfterDelayAsync(() => _mqttMsg = null);
        }
        catch (Exception ex)
        {
            _mqttError = true;
            _mqttMsg = $"Errore: {ex.Message}";
        }
        finally { _mqttSaving = false; }
    }

    private async Task ClearMsgAfterDelayAsync(Action clear)
    {
        await Task.Delay(3000);
        clear();
        StateHasChanged();
    }

    // ── settings models ───────────────────────────────────────────────────────
    private class ViessmannSettings
    {
        public string ApiBaseUrl { get; set; } = string.Empty;
        public string TokenEndpoint { get; set; } = string.Empty;
        public string ClientId { get; set; } = string.Empty;
        public string ClientSecret { get; set; } = string.Empty;
        public string? InstallationId { get; set; }
        public string? GatewaySerial { get; set; }
        public int PollIntervalSeconds { get; set; } = 300;
    }

    private class HuaweiSettings
    {
        public string BaseUrl { get; set; } = string.Empty;
        public string UserName { get; set; } = string.Empty;
        public string SystemCode { get; set; } = string.Empty;
        public string? StationCode { get; set; }
        public int PollIntervalSeconds { get; set; } = 300;
    }

    private class DaikinSettings
    {
        public string TokenEndpoint { get; set; } = string.Empty;
        public string ApiBaseUrl { get; set; } = string.Empty;
        public string ClientId { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public int PollIntervalSeconds { get; set; } = 300;
    }

    private class WallboxSettings
    {
        public int Port { get; set; } = 9000;
        public string? AuthKey { get; set; }
        public int HeartbeatTimeoutSeconds { get; set; } = 60;
    }

    private class MqttSettings
    {
        public string Host { get; set; } = string.Empty;
        public int Port { get; set; } = 1883;
        public string ClientId { get; set; } = string.Empty;
        public string? Username { get; set; }
        public string? Password { get; set; }
        public bool UseTls { get; set; }
    }
}
