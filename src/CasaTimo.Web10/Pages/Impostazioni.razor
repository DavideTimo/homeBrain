@page "/impostazioni"
@attribute [Authorize]
@inject ApiClient Api
@inject NotificationService PushService
@inject IJSRuntime JS

<PageTitle>Impostazioni — Casa Timò</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">Impostazioni</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Le modifiche ai connettori richiedono il riavvio del servizio Workers per essere applicate.</MudText>

<MudCard Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">🔔 Notifiche Push</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (!_pushSupported)
        {
            <MudText Color="Color.Secondary">Le notifiche push non sono supportate da questo browser.</MudText>
        }
        else if (_pushSubscribed)
        {
            <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
                <MudText Color="Color.Success">✓ Notifiche attive su questo dispositivo</MudText>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="DisableNotifications">Disabilita</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="SendTestNotification">Invia test</MudButton>
            </div>
        }
        else
        {
            <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
                <MudText Color="Color.Secondary">Ricevi notifiche push per le scadenze bollette.</MudText>
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="EnableNotifications" Disabled="@_pushLoading">
                    @(_pushLoading ? "..." : "Abilita notifiche")
                </MudButton>
            </div>
        }
        @if (_pushMessage != null)
        {
            <MudAlert Severity="@(_pushError ? Severity.Error : Severity.Success)" Class="mt-2" Dense="true">@_pushMessage</MudAlert>
        }
    </MudCardContent>
</MudCard>

@if (_loading)
{
    <MudAlert Severity="Severity.Info">Caricamento...</MudAlert>
}
else
{
    <MudExpansionPanels MultiExpansion="true">

        <MudExpansionPanel>
            <TitleContent>
                <div style="display:flex; align-items:center; justify-content:space-between; width:100%;">
                    <MudText><strong>Viessmann (PDC + VMC)</strong></MudText>
                    @if (_viessmannUpdatedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Aggiornato: @_viessmannUpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</MudText>
                    }
                </div>
            </TitleContent>
            <ChildContent>
                <MudGrid>
                    <MudItem xs="12" md="6"><MudTextField Label="API Base URL" @bind-Value="_viessmann.ApiBaseUrl" Placeholder="https://api.viessmann.com" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Token Endpoint" @bind-Value="_viessmann.TokenEndpoint" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Client ID" @bind-Value="_viessmann.ClientId" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Client Secret" @bind-Value="_viessmann.ClientSecret" InputType="InputType.Password" AutoComplete="off" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Installation ID (opzionale)" @bind-Value="_viessmann.InstallationId" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Gateway Serial (opzionale)" @bind-Value="_viessmann.GatewaySerial" /></MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="int" Label="Intervallo di polling" @bind-Value="_viessmannPollMinutes">
                            <MudSelectItem Value="60">1 min</MudSelectItem>
                            <MudSelectItem Value="300">5 min</MudSelectItem>
                            <MudSelectItem Value="600">10 min</MudSelectItem>
                            <MudSelectItem Value="900">15 min</MudSelectItem>
                            <MudSelectItem Value="1800">30 min</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
                <div style="display:flex; align-items:center; gap:12px; margin-top:16px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveViessmann" Disabled="@_viessmannSaving">
                        @if (_viessmannSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> } Salva
                    </MudButton>
                    @if (_viessmannMsg != null)
                    {
                        <MudText Color="@(_viessmannError ? Color.Error : Color.Success)">@_viessmannMsg</MudText>
                    }
                </div>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <div style="display:flex; align-items:center; justify-content:space-between; width:100%;">
                    <MudText><strong>Huawei FusionSolar</strong></MudText>
                    @if (_huaweiUpdatedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Aggiornato: @_huaweiUpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</MudText>
                    }
                </div>
            </TitleContent>
            <ChildContent>
                <MudGrid>
                    <MudItem xs="12" md="6"><MudTextField Label="Base URL" @bind-Value="_huawei.BaseUrl" Placeholder="https://eu5.fusionsolar.huawei.com" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Username" @bind-Value="_huawei.UserName" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="System Code" @bind-Value="_huawei.SystemCode" InputType="InputType.Password" AutoComplete="off" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Station Code (opzionale)" @bind-Value="_huawei.StationCode" /></MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="int" Label="Intervallo di polling" @bind-Value="_huaweiPollMinutes">
                            <MudSelectItem Value="60">1 min</MudSelectItem>
                            <MudSelectItem Value="300">5 min</MudSelectItem>
                            <MudSelectItem Value="600">10 min</MudSelectItem>
                            <MudSelectItem Value="900">15 min</MudSelectItem>
                            <MudSelectItem Value="1800">30 min</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
                <div style="display:flex; align-items:center; gap:12px; margin-top:16px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveHuawei" Disabled="@_huaweiSaving">
                        @if (_huaweiSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> } Salva
                    </MudButton>
                    @if (_huaweiMsg != null)
                    {
                        <MudText Color="@(_huaweiError ? Color.Error : Color.Success)">@_huaweiMsg</MudText>
                    }
                </div>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <div style="display:flex; align-items:center; justify-content:space-between; width:100%;">
                    <MudText><strong>Daikin Cloud</strong></MudText>
                    @if (_daikinUpdatedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Aggiornato: @_daikinUpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</MudText>
                    }
                </div>
            </TitleContent>
            <ChildContent>
                <MudGrid>
                    <MudItem xs="12" md="6"><MudTextField Label="Token Endpoint" @bind-Value="_daikin.TokenEndpoint" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="API Base URL" @bind-Value="_daikin.ApiBaseUrl" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Client ID" @bind-Value="_daikin.ClientId" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Username" @bind-Value="_daikin.Username" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Password" @bind-Value="_daikin.Password" InputType="InputType.Password" AutoComplete="off" /></MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="int" Label="Intervallo di polling" @bind-Value="_daikinPollMinutes">
                            <MudSelectItem Value="60">1 min</MudSelectItem>
                            <MudSelectItem Value="300">5 min</MudSelectItem>
                            <MudSelectItem Value="600">10 min</MudSelectItem>
                            <MudSelectItem Value="900">15 min</MudSelectItem>
                            <MudSelectItem Value="1800">30 min</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
                <div style="display:flex; align-items:center; gap:12px; margin-top:16px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDaikin" Disabled="@_daikinSaving">
                        @if (_daikinSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> } Salva
                    </MudButton>
                    @if (_daikinMsg != null)
                    {
                        <MudText Color="@(_daikinError ? Color.Error : Color.Success)">@_daikinMsg</MudText>
                    }
                </div>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <div style="display:flex; align-items:center; justify-content:space-between; width:100%;">
                    <MudText><strong>Wallbox OCPP</strong></MudText>
                    @if (_wallboxUpdatedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Aggiornato: @_wallboxUpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</MudText>
                    }
                </div>
            </TitleContent>
            <ChildContent>
                <MudGrid>
                    <MudItem xs="12" md="4"><MudTextField T="int" Label="Porta" @bind-Value="_wallbox.Port" /></MudItem>
                    <MudItem xs="12" md="4"><MudTextField Label="Auth Key (opzionale)" @bind-Value="_wallbox.AuthKey" InputType="InputType.Password" AutoComplete="off" /></MudItem>
                    <MudItem xs="12" md="4"><MudTextField T="int" Label="Heartbeat Timeout (secondi)" @bind-Value="_wallbox.HeartbeatTimeoutSeconds" /></MudItem>
                </MudGrid>
                <div style="display:flex; align-items:center; gap:12px; margin-top:16px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveWallbox" Disabled="@_wallboxSaving">
                        @if (_wallboxSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> } Salva
                    </MudButton>
                    @if (_wallboxMsg != null)
                    {
                        <MudText Color="@(_wallboxError ? Color.Error : Color.Success)">@_wallboxMsg</MudText>
                    }
                </div>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <div style="display:flex; align-items:center; justify-content:space-between; width:100%;">
                    <MudText><strong>MQTT Broker</strong></MudText>
                    @if (_mqttUpdatedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Aggiornato: @_mqttUpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</MudText>
                    }
                </div>
            </TitleContent>
            <ChildContent>
                <MudGrid>
                    <MudItem xs="12" md="6"><MudTextField Label="Host" @bind-Value="_mqtt.Host" Placeholder="localhost" /></MudItem>
                    <MudItem xs="12" md="3"><MudTextField T="int" Label="Porta" @bind-Value="_mqtt.Port" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Client ID" @bind-Value="_mqtt.ClientId" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Username (opzionale)" @bind-Value="_mqtt.Username" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField Label="Password (opzionale)" @bind-Value="_mqtt.Password" InputType="InputType.Password" AutoComplete="off" /></MudItem>
                    <MudItem xs="12"><MudCheckBox T="bool" Label="Usa TLS" @bind-Value="_mqtt.UseTls" /></MudItem>
                </MudGrid>
                <div style="display:flex; align-items:center; gap:12px; margin-top:16px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveMqtt" Disabled="@_mqttSaving">
                        @if (_mqttSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> } Salva
                    </MudButton>
                    @if (_mqttMsg != null)
                    {
                        <MudText Color="@(_mqttError ? Color.Error : Color.Success)">@_mqttMsg</MudText>
                    }
                </div>
            </ChildContent>
        </MudExpansionPanel>

    </MudExpansionPanels>
}

@code {
    private bool _loading = true;

    private bool _pushSupported;
    private bool _pushSubscribed;
    private bool _pushLoading;
    private string? _pushMessage;
    private bool _pushError;

    private ViessmannSettings _viessmann = new();
    private int _viessmannPollMinutes = 300;
    private DateTime? _viessmannUpdatedAt;
    private bool _viessmannSaving;
    private string? _viessmannMsg;
    private bool _viessmannError;

    private HuaweiSettings _huawei = new();
    private int _huaweiPollMinutes = 300;
    private DateTime? _huaweiUpdatedAt;
    private bool _huaweiSaving;
    private string? _huaweiMsg;
    private bool _huaweiError;

    private DaikinSettings _daikin = new();
    private int _daikinPollMinutes = 300;
    private DateTime? _daikinUpdatedAt;
    private bool _daikinSaving;
    private string? _daikinMsg;
    private bool _daikinError;

    private WallboxSettings _wallbox = new();
    private DateTime? _wallboxUpdatedAt;
    private bool _wallboxSaving;
    private string? _wallboxMsg;
    private bool _wallboxError;

    private MqttSettings _mqtt = new();
    private DateTime? _mqttUpdatedAt;
    private bool _mqttSaving;
    private string? _mqttMsg;
    private bool _mqttError;

    protected override async Task OnInitializedAsync()
    {
        _pushSupported = await PushService.IsSupportedAsync();
        if (_pushSupported)
            _pushSubscribed = await PushService.IsSubscribedAsync();

        await LoadConnectorsAsync();
        _loading = false;
    }

    private async Task LoadConnectorsAsync()
    {
        await LoadConnector("viessmann", dto =>
        {
            _viessmannUpdatedAt = dto.UpdatedAt;
            var s = Deserialize<ViessmannSettings>(dto.SettingsJson);
            if (s != null) { _viessmann = s; _viessmannPollMinutes = s.PollIntervalSeconds; }
        });
        await LoadConnector("huawei", dto =>
        {
            _huaweiUpdatedAt = dto.UpdatedAt;
            var s = Deserialize<HuaweiSettings>(dto.SettingsJson);
            if (s != null) { _huawei = s; _huaweiPollMinutes = s.PollIntervalSeconds; }
        });
        await LoadConnector("daikin", dto =>
        {
            _daikinUpdatedAt = dto.UpdatedAt;
            var s = Deserialize<DaikinSettings>(dto.SettingsJson);
            if (s != null) { _daikin = s; _daikinPollMinutes = s.PollIntervalSeconds; }
        });
        await LoadConnector("wallbox", dto =>
        {
            _wallboxUpdatedAt = dto.UpdatedAt;
            var s = Deserialize<WallboxSettings>(dto.SettingsJson);
            if (s != null) _wallbox = s;
        });
        await LoadConnector("mqtt", dto =>
        {
            _mqttUpdatedAt = dto.UpdatedAt;
            var s = Deserialize<MqttSettings>(dto.SettingsJson);
            if (s != null) _mqtt = s;
        });
    }

    private async Task LoadConnector(string name, Action<ConnectorConfigDto> apply)
    {
        try { var dto = await Api.GetConnectorConfigAsync(name); if (dto != null) apply(dto); }
        catch { }
    }

    private static readonly System.Text.Json.JsonSerializerOptions _jsonOpts = new()
    {
        PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };

    private static T? Deserialize<T>(string json)
    {
        try { return System.Text.Json.JsonSerializer.Deserialize<T>(json, _jsonOpts); }
        catch { return default; }
    }

    private static string Serialize<T>(T obj) => System.Text.Json.JsonSerializer.Serialize(obj, _jsonOpts);

    private async Task EnableNotifications()
    {
        _pushLoading = true; _pushMessage = null;
        try
        {
            var ok = await PushService.SubscribeAsync();
            _pushSubscribed = ok;
            _pushError = !ok;
            _pushMessage = ok ? "Notifiche abilitate." : "Impossibile abilitare le notifiche. Controlla i permessi del browser.";
        }
        catch (Exception ex) { _pushError = true; _pushMessage = $"Errore: {ex.Message}"; }
        finally { _pushLoading = false; }
    }

    private async Task DisableNotifications()
    {
        _pushMessage = null;
        try { await PushService.UnsubscribeAsync(); _pushSubscribed = false; _pushError = false; _pushMessage = "Notifiche disabilitate."; }
        catch (Exception ex) { _pushError = true; _pushMessage = $"Errore: {ex.Message}"; }
    }

    private async Task SendTestNotification()
    {
        _pushMessage = null;
        try { await Api.SendTestPushAsync(); _pushError = false; _pushMessage = "Notifica di test inviata."; }
        catch (Exception ex) { _pushError = true; _pushMessage = $"Errore: {ex.Message}"; }
    }

    private async Task SaveViessmann()
    {
        _viessmannSaving = true; _viessmannMsg = null;
        try
        {
            _viessmann.PollIntervalSeconds = _viessmannPollMinutes;
            await Api.SaveConnectorConfigAsync("viessmann", Serialize(_viessmann));
            _viessmannUpdatedAt = DateTime.Now; _viessmannError = false; _viessmannMsg = "✓ Salvato";
            _ = ClearMsgAfterDelayAsync(() => _viessmannMsg = null);
        }
        catch (Exception ex) { _viessmannError = true; _viessmannMsg = $"Errore: {ex.Message}"; }
        finally { _viessmannSaving = false; }
    }

    private async Task SaveHuawei()
    {
        _huaweiSaving = true; _huaweiMsg = null;
        try
        {
            _huawei.PollIntervalSeconds = _huaweiPollMinutes;
            await Api.SaveConnectorConfigAsync("huawei", Serialize(_huawei));
            _huaweiUpdatedAt = DateTime.Now; _huaweiError = false; _huaweiMsg = "✓ Salvato";
            _ = ClearMsgAfterDelayAsync(() => _huaweiMsg = null);
        }
        catch (Exception ex) { _huaweiError = true; _huaweiMsg = $"Errore: {ex.Message}"; }
        finally { _huaweiSaving = false; }
    }

    private async Task SaveDaikin()
    {
        _daikinSaving = true; _daikinMsg = null;
        try
        {
            _daikin.PollIntervalSeconds = _daikinPollMinutes;
            await Api.SaveConnectorConfigAsync("daikin", Serialize(_daikin));
            _daikinUpdatedAt = DateTime.Now; _daikinError = false; _daikinMsg = "✓ Salvato";
            _ = ClearMsgAfterDelayAsync(() => _daikinMsg = null);
        }
        catch (Exception ex) { _daikinError = true; _daikinMsg = $"Errore: {ex.Message}"; }
        finally { _daikinSaving = false; }
    }

    private async Task SaveWallbox()
    {
        _wallboxSaving = true; _wallboxMsg = null;
        try
        {
            await Api.SaveConnectorConfigAsync("wallbox", Serialize(_wallbox));
            _wallboxUpdatedAt = DateTime.Now; _wallboxError = false; _wallboxMsg = "✓ Salvato";
            _ = ClearMsgAfterDelayAsync(() => _wallboxMsg = null);
        }
        catch (Exception ex) { _wallboxError = true; _wallboxMsg = $"Errore: {ex.Message}"; }
        finally { _wallboxSaving = false; }
    }

    private async Task SaveMqtt()
    {
        _mqttSaving = true; _mqttMsg = null;
        try
        {
            await Api.SaveConnectorConfigAsync("mqtt", Serialize(_mqtt));
            _mqttUpdatedAt = DateTime.Now; _mqttError = false; _mqttMsg = "✓ Salvato";
            _ = ClearMsgAfterDelayAsync(() => _mqttMsg = null);
        }
        catch (Exception ex) { _mqttError = true; _mqttMsg = $"Errore: {ex.Message}"; }
        finally { _mqttSaving = false; }
    }

    private async Task ClearMsgAfterDelayAsync(Action clear)
    {
        await Task.Delay(3000);
        clear();
        StateHasChanged();
    }

    private class ViessmannSettings
    {
        public string ApiBaseUrl { get; set; } = string.Empty;
        public string TokenEndpoint { get; set; } = string.Empty;
        public string ClientId { get; set; } = string.Empty;
        public string ClientSecret { get; set; } = string.Empty;
        public string? InstallationId { get; set; }
        public string? GatewaySerial { get; set; }
        public int PollIntervalSeconds { get; set; } = 300;
    }

    private class HuaweiSettings
    {
        public string BaseUrl { get; set; } = string.Empty;
        public string UserName { get; set; } = string.Empty;
        public string SystemCode { get; set; } = string.Empty;
        public string? StationCode { get; set; }
        public int PollIntervalSeconds { get; set; } = 300;
    }

    private class DaikinSettings
    {
        public string TokenEndpoint { get; set; } = string.Empty;
        public string ApiBaseUrl { get; set; } = string.Empty;
        public string ClientId { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public int PollIntervalSeconds { get; set; } = 300;
    }

    private class WallboxSettings
    {
        public int Port { get; set; } = 9000;
        public string? AuthKey { get; set; }
        public int HeartbeatTimeoutSeconds { get; set; } = 60;
    }

    private class MqttSettings
    {
        public string Host { get; set; } = string.Empty;
        public int Port { get; set; } = 1883;
        public string ClientId { get; set; } = string.Empty;
        public string? Username { get; set; }
        public string? Password { get; set; }
        public bool UseTls { get; set; }
    }
}
