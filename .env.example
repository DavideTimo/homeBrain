# Copia questo file in .env e compila i valori reali
# Il file .env NON va mai committato su Git

# JWT — chiave segreta minimo 32 caratteri
Jwt__Key=CAMBIA_CON_UNA_CHIAVE_SEGRETA_DI_ALMENO_32_CARATTERI

# Credenziali accesso app
Auth__Username=davide
Auth__Password=CAMBIA_CON_LA_TUA_PASSWORD

# Viessmann API — registra credenziali su developer.viessmann.com
Viessmann__ApiBaseUrl=https://api.viessmann.com
Viessmann__TokenEndpoint=https://iam.viessmann.com/idp/v3/token
Viessmann__ClientId=
Viessmann__ClientSecret=
# Viessmann__InstallationId=   # opzionale: pre-configura per saltare la discovery
# Viessmann__GatewaySerial=    # opzionale

# Huawei FusionSolar — credenziali del portale installer su eu5.fusionsolar.huawei.com
# UserName = username dell'account di terze parti (non l'account proprietario)
# SystemCode = la "system code" / password API configurata nel portale
Huawei__UserName=
Huawei__SystemCode=
# Huawei__StationCode=   # opzionale: auto-discover se lasciato vuoto

# Daikin Cloud Europe — credenziali del portale Daikin Cloud (app Daikin Mobile Controller)
Daikin__Username=
Daikin__Password=

# Wallbox OCPP — la wallbox si connette a noi, configurare nel portale della wallbox:
#   WebSocket URL: ws://IP_SERVER:9000/ocpp/{chargePointId}
#   Subprotocol: ocpp1.6
# Wallbox__AuthKey=    # opzionale: chiave Basic Auth per accettare solo la tua wallbox
