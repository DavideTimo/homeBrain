# ─── CasaTimo — variabili d'ambiente ─────────────────────────────────────────
# Copia questo file in .env (escluso da git) e compila i valori reali.
# In Docker usa --env-file .env  oppure il blocco "environment:" in docker-compose.
# In sviluppo locale puoi usare "dotnet user-secrets set" (vedi README).
#
# Convenzione .NET: i doppi underscore (__) sostituiscono il separatore ':'.
# Es. CASATIMO_API__Jwt__Key  →  config["Jwt:Key"]

# ── API ───────────────────────────────────────────────────────────────────────
# Password amministratore per ottenere il JWT
CASATIMO_API__AdminPassword=CHANGE_ME

# Chiave HMAC-SHA256 per la firma dei JWT (minimo 32 caratteri)
CASATIMO_API__Jwt__Key=CHANGE_ME_USE_A_LONG_RANDOM_STRING_MIN_32_CHARS

# Origini CORS consentite (URL del frontend Blazor)
CASATIMO_API__AllowedOrigins__0=http://localhost:5228

# Percorso del database SQLite condiviso tra API e Workers
CASATIMO_API__ConnectionStrings__CasaTimoDb=Data Source=/data/casatimo.db
CASATIMO_WORKERS__ConnectionStrings__CasaTimoDb=Data Source=/data/casatimo.db

# ── Workers ───────────────────────────────────────────────────────────────────
# Credenziali MQTT (opzionali se il broker non richiede autenticazione)
CASATIMO_WORKERS__Mqtt__Username=
CASATIMO_WORKERS__Mqtt__Password=

# Percorso del database SQLite (stesso dell'API se condiviso)
CASATIMO_WORKERS__ConnectionStrings__CasaTimoDb=Data Source=/data/casatimo.db

# ── Viessmann (opzionale) ─────────────────────────────────────────────────────
CASATIMO_WORKERS__Viessmann__TokenEndpoint=
CASATIMO_WORKERS__Viessmann__ApiBaseUrl=
CASATIMO_WORKERS__Viessmann__ClientId=
CASATIMO_WORKERS__Viessmann__ClientSecret=
CASATIMO_WORKERS__Viessmann__Username=
CASATIMO_WORKERS__Viessmann__Password=
